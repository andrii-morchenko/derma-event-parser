# Email recipients (comma-separated)
NOTIFY_EMAILS=your@email.com,another@email.com

# SMTP settings (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# Days before event to warn (default: 7)
WARN_DAYS=7

# Cron expression (default: midnight BST daily)
CRON_EXPR=0 0 * * *
